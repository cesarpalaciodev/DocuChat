# OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# OpenRouter (gratis, acepta Gmail) - openrouter.ai/keys
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3-8b-instruct

# Groq (necesita Google Workspace) - console.groq.com/keys
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama3-8b-8192

# DeepSeek (barato, acepta Gmail) - platform.deepseek.com
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

LLM_API_KEY=tu_api_key_aqui
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3-8b-instruct

# Embeddings (set EMBEDDING_ENABLED=true for semantic search via API)
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small

VECTOR_STORE_DIR=data/vectors
CLONE_DIR=data/cloned_repos
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4
HOST=0.0.0.0
PORT=8000

# Security settings
ALLOWED_HOSTS=github.com,gitlab.com,bitbucket.org
MAX_TOTAL_CHUNKS=20000
MAX_FILE_SIZE=500000
CLONE_TIMEOUT_SECONDS=60
MAX_CONCURRENT_CLONES=3

# CORS
CORS_ORIGINS=http://localhost:8000,http://localhost:5173

# Auth (set AUTH_ENABLED=true + API_KEY for protection)
AUTH_ENABLED=false
API_KEY=your-secret-api-key

# Rate limiting (per endpoint tier)
RATE_LIMIT_ENABLED=true
RATE_LIGHT_RPM=300
RATE_MEDIUM_RPM=60
RATE_HEAVY_RPM=20
RATE_EXPENSE_RPM=5
RATE_WINDOW_SECONDS=60

# LLM settings
LLM_TIMEOUT_SECONDS=60
LLM_STREAM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
